# 新闻自动更新定时任务
# 每天北京时间早上8点执行 (UTC 0:00)

# 设置环境变量
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
HOME=/home/user

# 每天 UTC 00:00 执行 (北京时间 08:00)
0 0 * * * cd /mnt/okcomputer/output/app && /usr/bin/python3 scripts/daily_news_check.py >> /mnt/okcomputer/output/app/logs/news_update.log 2>&1

# 可选：每小时检查一次（调试用）
# 0 * * * * cd /mnt/okcomputer/output/app && /usr/bin/python3 scripts/daily_news_check.py >> /mnt/okcomputer/output/app/logs/news_update.log 2>&1
